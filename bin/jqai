#!/bin/bash
set -e

usage() {
    echo "Usage: jqai <description> [file]"
    echo "       cat file.json | jqai <description>"
    echo ""
    echo "Like jq, but for dummies."
    echo "Uses Claude to generate the jq selector from your description."
    echo ""
    echo "Examples:"
    echo "  jqai 'get all user names' data.json"
    echo "  cat data.json | jqai 'extract ids where status is active'"
    exit 1
}

if [ -z "$1" ] || [ "$1" = "-h" ] || [ "$1" = "--help" ]; then
    usage
fi

description="$1"
shift

if [ -n "$1" ]; then
    json_input=$(cat "$1")
else
    json_input=$(cat)
fi

json_sample=$(echo "$json_input" | head -c 2048)
json_structure=$(echo "$json_input" | jq -r 'paths | join(".")' 2>/dev/null | head -100 || echo "")

if [ -n "$json_structure" ]; then
    prompt="Output ONLY a valid jq expression. No explanation, no markdown, no code blocks, no text before or after. Just the jq expression on a single line.

JSON structure (paths):
$json_structure

JSON sample:
$json_sample

Request: $description"
else
    prompt="Output ONLY a valid jq expression. No explanation, no markdown, no code blocks, no text before or after. Just the jq expression on a single line.

JSON sample:
$json_sample

Request: $description"
fi



echo "Generating jq selector..." >&2
raw_output=$(claude -p "$prompt" --model haiku --no-session-persistence 2>&1)
claude_exit=$?
if [ $claude_exit -ne 0 ]; then
    echo "Error: Claude command failed (exit code: $claude_exit)" >&2
    echo "Output: $raw_output" >&2
    exit 1
fi
if [ -z "$raw_output" ]; then
    echo "Error: Claude returned empty output" >&2
    exit 1
fi
# Extract jq expression: remove markdown code blocks first
cleaned=$(echo "$raw_output" | sed 's/^```jq//; s/^```//; s/```$//')
# Try to find a line that starts with . or [ (most common jq patterns)
candidate=$(echo "$cleaned" | grep -E '^\s*[.[]' | head -1)
if [ -n "$candidate" ]; then
    # Extract jq expression: stop at common explanation words (case-insensitive)
    selector=$(echo "$candidate" | sed -E 's/[[:space:]]+(Wait|Actually|But|Given|Looking|Based|let|me|reconsider|pattern|shown|simplest|answer|assuming).*$//i' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
fi
# If still empty or if no line starting with . or [, try extracting from anywhere
if [ -z "$selector" ]; then
    # Look for jq pattern starting with .field
    selector=$(echo "$cleaned" | grep -oE '\.[a-zA-Z_][a-zA-Z0-9_.\[\|"'"'"' ]*' | head -1 | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
fi
# Last resort: take first non-empty line
if [ -z "$selector" ]; then
    selector=$(echo "$cleaned" | grep -v '^[[:space:]]*$' | head -1 | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
fi
if [ -z "$selector" ]; then
    echo "Error: Failed to extract jq selector from Claude output" >&2
    echo "Raw output was:" >&2
    echo "$raw_output" >&2
    exit 1
fi

echo "Running: jq '$selector'" >&2

echo "$json_input" | jq "$selector"
